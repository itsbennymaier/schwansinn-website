.s-eye{font-size:.7rem;text-transform:uppercase;letter-spacing:.22em;color:var(--a);margin-bottom:.55rem}
.s-ttl{font-size:clamp(1.7rem,6vw,2.75rem);font-weight:900;letter-spacing:-.03em;margin-bottom:.4rem}
.s-ln{width:2.25rem;height:2px;background:var(--a);border-radius:2px;margin:1rem 0 2rem}
.db-loading{color:var(--m);font-size:.88rem;text-align:center;padding:2.5rem;opacity:.7}
.db-empty{color:var(--m);font-size:.88rem;text-align:center;padding:2rem;background:var(--s2);border-radius:var(--r)}

/* ABOUT */
#about{background:var(--s1)}
.about-body p{color:var(--m);line-height:1.85;font-size:.93rem;margin-bottom:1rem}
.acards{display:grid;gap:.65rem}
.acard{background:var(--s2);border:1px solid var(--bd);border-left:3px solid var(--a);border-radius:var(--r);padding:1.1rem 1.35rem;transition:transform .2s}
.acard:hover{transform:translateX(3px)}
.acard h4{font-size:.74rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--a);margin-bottom:.35rem}
.acard p{font-size:.86rem;color:var(--m);line-height:1.75}

/* GALERIE */
#galerie{background:var(--bg)}
.g-grid{display:grid;grid-template-columns:1fr 1fr;gap:.45rem;margin-top:1.5rem;min-height:200px}
.gi{position:relative;aspect-ratio:4/3;overflow:hidden;border-radius:8px;cursor:pointer;background:var(--s2)}
.gi.w{grid-column:span 2;aspect-ratio:16/7}
.gi img{width:100%;height:100%;object-fit:cover;transition:transform .45s ease}
.gi:hover img{transform:scale(1.06)}
.go{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82) 0%,transparent 55%);display:flex;flex-direction:column;justify-content:flex-end;padding:.75rem .875rem;opacity:0;transition:opacity .28s}
.gi:hover .go{opacity:1}
.go h4{font-size:.82rem;font-weight:600}
.go span{font-size:.7rem;color:var(--a)}

/* LIGHTBOX */
.lb{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.96);display:flex;align-items:center;justify-content:center;padding:1.25rem;opacity:0;pointer-events:none;transition:opacity .3s}
.lb.o{opacity:1;pointer-events:all}
.lb img{max-width:100%;max-height:88vh;object-fit:contain;border-radius:6px}
.lb-x{position:absolute;top:.875rem;right:1.1rem;font-size:1.7rem;color:var(--m);cursor:pointer;transition:color .2s}
.lb-x:hover{color:var(--t)}
.lb-cap{position:absolute;bottom:1.25rem;left:50%;translate:-50%;text-align:center;white-space:nowrap}
.lb-cap strong{font-size:.88rem;display:block}
.lb-cap span{font-size:.75rem;color:var(--a)}

/* TERMINE */
#termine{background:var(--s1)}
.ev-spot{background:linear-gradient(135deg,rgba(249,178,53,.06) 0%,transparent 65%);border:1px solid rgba(249,178,53,.2);border-top:2px solid var(--a);border-radius:14px;padding:1.75rem;margin-bottom:1rem;position:relative;overflow:hidden}
.ev-spot::after{content:'';position:absolute;bottom:-40px;right:-40px;width:160px;height:160px;background:radial-gradient(circle,rgba(249,178,53,.06),transparent 70%);border-radius:50%;pointer-events:none}
.ev-top-row{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1.5rem}
.ev-pill{display:inline-flex;align-items:center;gap:.45rem;font-size:.68rem;text-transform:uppercase;letter-spacing:.14em;color:var(--a);background:rgba(249,178,53,.1);border:1px solid rgba(249,178,53,.22);padding:.3rem .85rem;border-radius:20px}
.ev-pill-dot{width:6px;height:6px;border-radius:50%;background:var(--a);animation:blink 1.6s ease-in-out infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.ev-cdwn{font-size:.85rem;color:var(--m)}
.ev-cdwn strong{color:var(--a);font-size:1.05rem;font-weight:800}
.ev-body{display:flex;align-items:flex-start;gap:1.25rem;margin-bottom:1.75rem}
.ev-datebox{text-align:center;flex-shrink:0}
.ev-bday{font-size:clamp(2.8rem,10vw,4rem);font-weight:900;color:var(--a);line-height:1}
.ev-bmonth{font-size:.75rem;text-transform:uppercase;letter-spacing:.14em;color:var(--m)}
.ev-byear{font-size:.75rem;color:var(--m)}
.ev-vline{width:1px;background:var(--bd);align-self:stretch;flex-shrink:0;margin:0 .25rem;display:none}
.ev-detail h3{font-size:clamp(1rem,4vw,1.35rem);font-weight:800;margin-bottom:.5rem;line-height:1.25}
.ev-detail p{font-size:.85rem;color:var(--m);margin-bottom:.25rem;display:flex;align-items:center;gap:.4rem}
.ev-free-tag{display:inline-block;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:#000;background:var(--a);padding:.18rem .65rem;border-radius:4px;font-weight:700;margin-top:.5rem}
.ev-ctas{display:flex;flex-wrap:wrap;gap:.65rem}
.ev-more{text-align:center;color:var(--m);font-size:.82rem;margin-top:1rem}
.ev-more a{color:var(--a);border-bottom:1px solid rgba(249,178,53,.3)}
.no-ev{text-align:center;padding:2.5rem;background:var(--s2);border-radius:var(--r);color:var(--m);font-size:.9rem}

/* BESETZUNG */
#besetzung{background:var(--bg)}
.reg{margin-bottom:2.5rem}
.reg-lbl{font-size:.7rem;text-transform:uppercase;letter-spacing:.18em;color:var(--a);display:flex;align-items:center;gap:.75rem;margin-bottom:.875rem}
.reg-lbl::after{content:'';flex:1;height:1px;background:var(--bd)}
.mg{display:grid;grid-template-columns:repeat(2,1fr);gap:.55rem}
.mc{background:var(--s2);border:1px solid var(--bd);border-radius:10px;overflow:hidden;position:relative;transition:border-color .22s,transform .22s;cursor:pointer}
.mc:hover{border-color:var(--a);transform:translateY(-3px)}
.mc img,.mc-ph{width:100%;aspect-ratio:1;object-fit:cover;object-position:top;display:block;background:var(--bg)}
.mc-ph{display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:900;color:var(--a)}
.mc-b{padding:.7rem .875rem}
.mc-n{font-size:.85rem;font-weight:700;line-height:1.25}
.mc-r{font-size:.7rem;color:var(--a);margin-top:.15rem}
.mc-ov{position:absolute;inset:0;background:rgba(8,8,8,.93);display:flex;flex-direction:column;justify-content:center;padding:1rem;opacity:0;transition:opacity .25s;pointer-events:none}
@media(hover:hover) and (pointer:fine){.mc:hover .mc-ov{opacity:1;pointer-events:all}}
.mc.ta .mc-ov{opacity:1;pointer-events:all}
.mc-ov .ovn{font-size:.82rem;font-weight:700;color:var(--a);margin-bottom:.4rem}
.mc-ov .ovd{font-size:.77rem;color:#bbb;line-height:1.65}
.mc-tap-hint{font-size:.65rem;color:var(--m);text-align:center;margin-bottom:.85rem;display:none}

/* KONTAKT */
#kontakt{background:var(--s1)}
.k-info p{color:var(--m);font-size:.9rem;line-height:1.82;margin-bottom:1.25rem}
.k-link{display:inline-flex;align-items:center;gap:.6rem;color:var(--a);font-size:.92rem;transition:color .2s;margin-bottom:.5rem}
.k-link:hover{color:var(--a2)}
.kf{display:grid;gap:.75rem}
.frow{display:grid;gap:.75rem}
.fg{display:grid;gap:.28rem}
.fg label{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--m)}
.fg input,.fg select,.fg textarea{background:var(--s2);border:1px solid var(--bd);border-radius:7px;padding:.68rem .9rem;color:var(--t);font-size:.9rem;width:100%;font-family:inherit;transition:border-color .2s;-webkit-appearance:none}
.fg input:focus,.fg textarea:focus{outline:none;border-color:var(--a)}
.fg select{cursor:pointer}
.fg textarea{min-height:105px;resize:vertical}
.btn-snd{background:var(--a);color:#000;font-weight:800;font-size:.92rem;border-radius:7px;padding:.82rem;width:100%;transition:background .2s,transform .2s;cursor:pointer;border:none;font-family:inherit}
.btn-snd:hover{background:var(--a2);transform:translateY(-2px)}

/* FOOTER */
footer{background:#050505;border-top:1px solid var(--bd);padding:2.5rem 1.25rem;text-align:center}
.ft-logo{height:44px;width:auto;margin:0 auto .75rem}
footer p{color:var(--m);font-size:.78rem;line-height:2}
footer a{color:var(--a)}

/* DESKTOP */
@media(min-width:640px){.frow{grid-template-columns:1fr 1fr}}
@media(min-width:768px){
  nav{padding:0 2rem}
  .nav-ul{display:flex}
  .nav-book{display:inline-block}
  .hbg{display:none}
  section{padding:5.5rem 2rem}
  .about-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
  .g-grid{grid-template-columns:repeat(4,1fr);gap:.65rem}
  .mg{grid-template-columns:repeat(auto-fill,minmax(165px,1fr))}
  .k-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
  .k-info{margin-bottom:0}
  .h-stats{gap:4rem}
  .ev-body{gap:2rem}
  .ev-vline{display:block}
}
</style>
</head>
