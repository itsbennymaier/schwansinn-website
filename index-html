<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--a:#f9b235;--a2:#ffca5a;--bg:#080808;--s1:#101010;--s2:#181818;--bd:#222;--t:#f0ede6;--m:#747474;--r:10px}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--t);font-family:'Segoe UI',system-ui,sans-serif;line-height:1.65;overflow-x:hidden}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap}
.rv{opacity:0;transform:translateY(22px);transition:opacity .65s ease,transform .65s ease}
.rv.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* NAV */
nav{position:fixed;inset:0 0 auto;z-index:999;height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 1.1rem;background:rgba(8,8,8,.9);backdrop-filter:blur(18px);border-bottom:1px solid var(--bd)}
.nav-logo{height:32px;width:auto;object-fit:contain}
.nav-ul{display:none;list-style:none;gap:1.75rem}
.nav-ul a{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--m);transition:color .2s}
.nav-ul a:hover{color:var(--a)}
.nav-r{display:flex;align-items:center;gap:.75rem}
.nav-book{display:none;background:var(--a);color:#000;font-size:.78rem;font-weight:800;padding:.38rem 1rem;border-radius:5px;transition:background .2s}
.nav-book:hover{background:var(--a2)}
.hbg{display:flex;flex-direction:column;gap:5px;padding:8px}
.hbg span{display:block;width:20px;height:2px;background:var(--t);border-radius:2px;transition:all .28s}
.hbg.o span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.hbg.o span:nth-child(2){opacity:0;transform:scaleX(0)}
.hbg.o span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* MOBILE MENU */
.mob{position:fixed;inset:0;z-index:998;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2.25rem;opacity:0;pointer-events:none;transition:opacity .3s}
.mob.o{opacity:1;pointer-events:all}
.mob a{font-size:1.65rem;font-weight:800;color:var(--t);transition:color .2s}
.mob a:hover{color:var(--a)}
.mob-cta{background:var(--a)!important;color:#000!important;padding:.75rem 2.5rem;border-radius:8px;margin-top:.5rem;font-size:1.3rem!important}

/* HERO */
#hero{min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:70px 1.5rem 3rem;position:relative;overflow:hidden}
.h-glow{position:absolute;top:35%;left:50%;translate:-50% -50%;width:min(500px,120vw);height:min(500px,120vw);background:radial-gradient(circle,rgba(249,178,53,.1) 0%,transparent 68%);border-radius:50%;animation:glow 5s ease-in-out infinite;pointer-events:none}
@keyframes glow{0%,100%{opacity:.7;transform:scale(1)}50%{opacity:1;transform:scale(1.1)}}
.h-grid{position:absolute;inset:0;opacity:.025;background-image:linear-gradient(#f9b235 1px,transparent 1px),linear-gradient(90deg,#f9b235 1px,transparent 1px);background-size:48px 48px;pointer-events:none}
.h-logo{height:clamp(90px,20vw,160px);width:auto;margin:0 auto 1.5rem;position:relative;z-index:1;animation:fadeup .6s ease both .08s;filter:drop-shadow(0 4px 24px rgba(249,178,53,.18))}
.h-sub{font-size:clamp(.88rem,3.5vw,1.12rem);color:var(--m);max-width:460px;margin:0 auto 2rem;animation:fadeup .6s ease both .32s;line-height:1.78;position:relative;z-index:1}
.h-btns{display:flex;flex-wrap:wrap;gap:.65rem;justify-content:center;animation:fadeup .6s ease both .48s;position:relative;z-index:1}
