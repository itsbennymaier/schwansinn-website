.h-stats{display:flex;gap:2.5rem;margin-top:3rem;padding-top:2.5rem;border-top:1px solid var(--bd);justify-content:center;animation:fadeup .6s ease both .62s;position:relative;z-index:1}
.stat-n{font-size:1.85rem;font-weight:900;color:var(--a);line-height:1;display:block}
.stat-l{font-size:.67rem;text-transform:uppercase;letter-spacing:.12em;color:var(--m);margin-top:.2rem}
