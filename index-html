    <div class="k-wrap">
      <div class="k-info rv d2">
        <p>Ihr plant ein Sommerfest, Jubiläum, Festival oder eine andere Veranstaltung und sucht eine Blaskapelle, die garantiert für Stimmung sorgt? Schreibt uns – wir melden uns schnell und unkompliziert zurück.</p>
        <a class="k-link" href="mailto:schwansinn@gmx.com">✉ schwansinn@gmx.com</a>
        <p style="margin-top:1rem;font-size:.82rem;color:var(--m)">📍 Schwarzwald-Baar-Kreis, Baden-Württemberg</p>
      </div>
      <div class="rv d3">
        <div class="kf">
          <div class="frow">
            <div class="fg"><label>Vorname</label><input type="text" placeholder="Max" autocomplete="given-name"></div>
            <div class="fg"><label>Nachname</label><input type="text" placeholder="Mustermann" autocomplete="family-name"></div>
          </div>
          <div class="fg"><label>E-Mail</label><input type="email" placeholder="deine@email.de" autocomplete="email"></div>
          <div class="fg"><label>Anlass</label><select><option value="">Bitte wählen…</option><option>Sommerfest</option><option>Jubiläum</option><option>Festival</option><option>Festzelt</option><option>Firmenveranstaltung</option><option>Stadtfest</option><option>Sonstiges</option></select></div>
          <div class="fg"><label>Nachricht</label><textarea placeholder="Erzählt uns von eurer Veranstaltung – Datum, Ort, Rahmen…"></textarea></div>
          <button class="btn-snd" onclick="alert('Vielen Dank! Diese Funktion wird in der Live-Version aktiv sein.')">Anfrage senden →</button>
        </div>
      </div>
    </div>
  </div>
</section>

<footer>
  <img class="ft-logo" src="https://www.schwansinn.de/images/team/logo-schwansinn.png" alt="Blaskapelle Schwansinn" onerror="this.style.display='none'">
  <p>Blaskapelle Schwansinn · Schwarzwald-Baar-Kreis<br>
  <a href="mailto:schwansinn@gmx.com">schwansinn@gmx.com</a><br>
  <a href="#">Impressum</a> · <a href="#">Datenschutz</a></p>
</footer>

<div class="lb" id="lb" onclick="clb()">
  <span class="lb-x" onclick="clb()">×</span>
  <img id="lbi" src="" alt="">
  <div class="lb-cap"><strong id="lbt"></strong><span id="lby"></span></div>
</div>

<script>
var SB = 'https://hqkpckckzegxqghdchrd.supabase.co';
var KEY = 'sb_publishable_VgY442Ty_q-Utae-8MMI8A_QPeqUz5U';
var REG_ORDER = ['Trompete & Flügelhorn','Holzregister','Mittleres Blech & Horn','Maschinenraum & Gesang'];

// ── SUPABASE ──
async function sbGet(table, params) {
  var res = await fetch(SB + '/rest/v1/' + table + '?' + params, {
    headers: { 'apikey': KEY, 'Content-Type': 'application/json' }
  });
  if (!res.ok) throw new Error('Fehler beim Laden');
  return res.json();
}

// ── HELPERS ──
function fmtDay(iso) { return new Date(iso + 'T12:00:00').getDate(); }
function fmtMonth(iso) { return new Date(iso + 'T12:00:00').toLocaleDateString('de-DE',{month:'short'}); }
function fmtYear(iso) { return new Date(iso + 'T12:00:00').getFullYear(); }
function daysLeft(iso) { return Math.max(0, Math.ceil((new Date(iso + 'T23:59:59') - new Date()) / 86400000)); }
function isFuture(iso) { return new Date(iso + 'T23:59:59') >= new Date(); }
function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── MARQUEE ──
var MQS = ['Sommerfeste','Jubiläen','Festivals','Stadtfeste','Festzelte','Open-Air-Bühnen','Vereinsfeste','Firmenevents','Kulturveranstaltungen','Konzerte'];
var mq = [...MQS,...MQS].map(function(s){ return '<span>'+s+'</span><span class="dot">♪</span>'; }).join('');
document.getElementById('mqi').innerHTML = mq + mq;

// ── GALERIE ──
async function loadGalerie() {
  var el = document.getElementById('gg');
  try {
    var rows = await sbGet('galerie', 'select=*&order=reihenfolge.asc');
    if (!rows.length) { el.innerHTML = '<div class="db-empty">Noch keine Bilder vorhanden.</div>'; return; }
    el.innerHTML = '';
    rows.forEach(function(p) {
      var d = document.createElement('div');
      d.className = 'gi' + (p.breit ? ' w' : '');
      d.innerHTML = '<img src="' + p.bild_url + '" alt="' + esc(p.titel) + ' ' + (p.jahr||'') + '" loading="lazy"><div class="go"><h4>' + esc(p.titel) + '</h4><span>' + (p.jahr||'') + '</span></div>';
      d.onclick = function() { olb(p); };
      el.appendChild(d);
    });
  } catch(e) {
    el.innerHTML = '<div class="db-empty">Galerie konnte nicht geladen werden.</div>';
  }
}

// ── LIGHTBOX ──
function olb(p) {
  document.getElementById('lbi').src = p.bild_url;
  document.getElementById('lbt').textContent = p.titel;
  document.getElementById('lby').textContent = p.jahr || '';
  document.getElementById('lb').classList.add('o');
}
function clb() { document.getElementById('lb').classList.remove('o'); }
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') clb(); });

// ── TERMINE ──
async function loadTermine() {
  var el = document.getElementById('evl');
  try {
    var rows = await sbGet('termine', 'select=*&order=datum.asc');
    var future = rows.filter(function(t) { return isFuture(t.datum); });
    if (!future.length) {
      el.innerHTML = '<div class="no-ev">Weitere Termine folgen in Kürze – schaut bald wieder rein!</div>';
      return;
    }
    el.innerHTML = future.map(function(t) {
      var days = daysLeft(t.datum);
      var cdwn = days > 0
        ? '<span class="ev-cdwn">Noch <strong>' + days + '</strong> ' + (days === 1 ? 'Tag' : 'Tage') + '</span>'
        : '<span class="ev-cdwn" style="color:var(--a)">Heute!</span>';
      var maps = t.maps_link || ('https://maps.google.com/?q=' + encodeURIComponent((t.adresse || t.ort || '')));
      return '<div class="ev-spot">' +
        '<div class="ev-top-row"><div class="ev-pill"><span class="ev-pill-dot"></span>Demnächst</div>' + cdwn + '</div>' +
        '<div class="ev-body">' +
          '<div class="ev-datebox"><div class="ev-bday">' + fmtDay(t.datum) + '.</div><div class="ev-bmonth">' + fmtMonth(t.datum) + '</div><div class="ev-byear">' + fmtYear(t.datum) + '</div></div>' +
          '<div class="ev-vline"></div>' +
          '<div class="ev-detail">' +
            '<h3>' + esc(t.titel) + '</h3>' +
            (t.uhrzeit_von ? '<p>🕖 ' + esc(t.uhrzeit_von) + (t.uhrzeit_bis ? ' – ' + esc(t.uhrzeit_bis) : '') + '</p>' : '') +
            (t.ort ? '<p>📍 ' + esc(t.ort) + (t.adresse ? ', ' + esc(t.adresse) : '') + '</p>' : '') +
            (t.eintritt_frei ? '<span class="ev-free-tag">Freier Eintritt</span>' : '') +
          '</div>' +
        '</div>' +
        '<div class="ev-ctas"><a href="#kontakt" class="btn btn-p">Ich komme! →</a><a href="' + maps + '" target="_blank" rel="noopener" class="btn btn-o">Route planen ↗</a></div>' +
      '</div>';
    }).join('') + '<p class="ev-more">Weitere Auftritte folgen in Kürze. <a href="#kontakt">Schreibt uns</a> für aktuelle Infos!</p>';
  } catch(e) {
    el.innerHTML = '<div class="no-ev">Termine konnten nicht geladen werden.</div>';
  }
}

// ── MUSIKER ──
async function loadMusiker() {
  var el = document.getElementById('mw');
  try {
    var rows = await sbGet('musiker', 'select=*&order=reihenfolge.asc');
    if (!rows.length) { el.innerHTML = '<div class="db-empty">Noch keine Musiker vorhanden.</div>'; return; }
    var groups = {};
    rows.forEach(function(m) {
      var r = m.register || 'Sonstige';
      if (!groups[r]) groups[r] = [];
      groups[r].push(m);
    });
    var regs = Object.keys(groups).sort(function(a, b) {
      var ai = REG_ORDER.indexOf(a), bi = REG_ORDER.indexOf(b);
      return (ai < 0 ? 99 : ai) - (bi < 0 ? 99 : bi);
    });
    el.innerHTML = regs.map(function(reg) {
      var cards = groups[reg].map(function(m) {
        var ini = m.name.split(' ').map(function(w){return w[0]||'';}).join('').slice(0,2).toUpperCase();
        return '<div class="mc">' +
          (m.bild_url ? '<img src="' + m.bild_url + '" alt="' + esc(m.name) + '" loading="lazy">' : '<div class="mc-ph">' + ini + '</div>') +
          '<div class="mc-b"><div class="mc-n">' + esc(m.name) + '</div><div class="mc-r">' + esc(m.instrument||'') + '</div></div>' +
          '<div class="mc-ov"><div class="ovn">' + esc(m.name) + '</div><div class="ovd">' + esc(m.beschreibung||'') + '</div></div>' +
        '</div>';
      }).join('');
      return '<div class="reg rv"><div class="reg-lbl">' + reg + '</div><div class="mg">' + cards + '</div></div>';
    }).join('');
    document.querySelectorAll('#mw .rv').forEach(function(el) { ro.observe(el); });
    setupTouch();
  } catch(e) {
    el.innerHTML = '<div class="db-empty">Besetzung konnte nicht geladen werden.</div>';
  }
}

// ── HAMBURGER ──
function tm() { document.getElementById('hbg').classList.toggle('o'); document.getElementById('mob').classList.toggle('o'); document.body.style.overflow = document.getElementById('mob').classList.contains('o') ? 'hidden' : ''; }
function cm() { document.getElementById('hbg').classList.remove('o'); document.getElementById('mob').classList.remove('o'); document.body.style.overflow = ''; }

// ── SCROLL REVEAL ──
var ro = new IntersectionObserver(function(es) {
  es.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('in'); ro.unobserve(e.target); } });
}, { threshold: .08 });
document.querySelectorAll('.rv').forEach(function(el) { ro.observe(el); });

// ── TOUCH MEMBERS ──
var isTouch = window.matchMedia('(hover:none),(pointer:coarse)').matches;
function setupTouch() {
  if (!isTouch) return;
  document.getElementById('tapHint').style.display = 'block';
  document.querySelectorAll('.mc').forEach(function(mc) {
    mc.addEventListener('click', function(e) {
      e.stopPropagation();
      var was = mc.classList.contains('ta');
      document.querySelectorAll('.mc.ta').forEach(function(x) { x.classList.remove('ta'); });
      if (!was) mc.classList.add('ta');
    });
  });
  document.addEventListener('click', function() { document.querySelectorAll('.mc.ta').forEach(function(x) { x.classList.remove('ta'); }); });
}

// ── COUNTER ──
var co = new IntersectionObserver(function(es) {
  es.forEach(function(e) {
    if (!e.isIntersecting) return;
    var el = e.target, to = +el.dataset.cnt, step = Math.max(2600/to, 20), n = 0;
    var t = setInterval(function() { n = Math.min(n+1, to); el.textContent = n; if (n >= to) clearInterval(t); }, step);
    co.unobserve(el);
  });
}, { threshold: .5 });
document.querySelectorAll('[data-cnt]').forEach(function(el) { co.observe(el); });

// ── START ──
loadGalerie();
loadTermine();
loadMusiker();
</script>
</body>
</html>
